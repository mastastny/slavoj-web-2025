# Server Configuration
SERVER_PORT=8080
PUBLIC_DOMAIN=http://localhost
SERVER_SECURE=true

# PostgreSQL Database Configuration
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=snpb

# Authentication & JWT Configuration
# REQUIRED: Secret key for JWT token signing (minimum 256 bits recommended)
JWT_SECRET_KEY=your-secret-key-at-least-256-bits-long

# JWT token lifespan in minutes (default: 15 minutes)
JWT_LIFESPAN=15

# Refresh token lifespan in days (default: 10 days)
REFRESH_TOKEN_LIFESPAN=10

# Days before expiration to rotate refresh token (default: 5 days)
REFRESH_TOKEN_ROTATION_THRESHOLD=5

# Bcrypt cost for password hashing (default: 10)
BCRYPT_PWD_COST=10

# Bcrypt cost for refresh token hashing (default: 10)
BCRYPT_REFRESH_TOKEN_COST=10

# Firebase Configuration
# REQUIRED: Either FIREBASE_SERVICE_ACCOUNT_JSON or FIREBASE_SERVICE_ACCOUNT_JSON_PATH must be set
# Path to Firebase service account JSON file
FIREBASE_SERVICE_ACCOUNT_JSON_PATH=path/to/service-account.json

# OR provide the JSON content directly (useful for Docker/cloud deployments)
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# REQUIRED: Firebase project ID
FIREBASE_PROJECT_ID=your-firebase-project-id

# Firebase database ID (default: "(default)")
FIREBASE_DATABASE_ID=(default)

# SendGrid Email Configuration
# REQUIRED: SendGrid API key for sending emails
SENDGRID_API_KEY=SG.your-sendgrid-api-key

# REQUIRED: From email address for outgoing emails
SENDGRID_FROM_EMAIL=noreply@example.com

# From name for outgoing emails (default: "Newsletter Platform")
SENDGRID_FROM_NAME=Newsletter Platform

# Use SendGrid EU region (default: false)
SENDGRID_USE_EU_REGION=false
